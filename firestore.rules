rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Auth helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'arlo.ktm01@gmail.com'; }
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'stock']);
      allow write: if isAdmin();
    }
    
    // Product Views
    match /product_views/{productId} {
      allow read, write: if true;
    }

    // Public Notifications
    match /public_notifications/{notificationId} {
      allow read, create: if true;
    }
    
    // Orders
    match /orders/{orderId} {
      // Allows anyone to place an order, even guests
      allow create: if true;
      // Anyone can get a single order by ID (for tracking)
      allow get: if true;
      // User can list their own orders; Admin can list all
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      // Only admin can update/delete status
      allow update, delete: if isAdmin();
    }
    
    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Analytics
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // Active Sessions
    match /active_sessions/{sessionId} {
      allow create, update, delete: if true;
      allow read: if isAdmin();
    }
  }
}
